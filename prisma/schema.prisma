generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  password          String
  company           String?
  currentPropertyId String?
  lookingForRoommate Boolean   @default(false)
  preferences       Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  currentProperty   Property?  @relation("CurrentPropertyResidents", fields: [currentPropertyId], references: [id])
  ownedProperties   Property[] @relation("OwnerProperties")
  wishlistEntries   Wishlist[]
  bookings          Booking[]
}

model Property {
  id                String     @id @default(cuid())
  ownerId           String
  title             String
  location          String
  price             Int
  image             String
  images            Json
  available         Boolean    @default(true)
  verified          Boolean    @default(false)
  distance          String
  rating            Float      @default(0)
  reviewCount       Int        @default(0)
  capacity          Int        @default(1)
  description       String
  roomType          String
  deposit           Int        @default(0)
  foodIncluded      Boolean    @default(false)
  highlights        Json
  amenities         Json
  houseRules        Json
  ownerPhone        String
  ownerResponseTime String
  ownerRole         String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  owner             User       @relation("OwnerProperties", fields: [ownerId], references: [id])
  residents         User[]     @relation("CurrentPropertyResidents")
  wishlistEntries   Wishlist[]
  bookings          Booking[]
}

model Wishlist {
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
}

model Booking {
  id             String   @id
  userId         String
  propertyId     String
  amount         Int
  currency       String
  status         String
  provider       String
  paymentOrderId String?
  paymentId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}
